<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Daily Opportunity Intelligence Report</title>
  <style>
    :root {
      color-scheme: light;
      --ink: #15202b;
      --muted: #5f6b7a;
      --line: #d9e1ea;
      --panel: #f7f9fb;
      --accent: #0f766e;
      --warn: #a16207;
    }
    body {
      margin: 0;
      font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      color: var(--ink);
      background: #ffffff;
      line-height: 1.5;
    }
    main {
      max-width: 1120px;
      margin: 0 auto;
      padding: 32px 20px 48px;
    }
    header {
      border-bottom: 1px solid var(--line);
      padding-bottom: 20px;
      margin-bottom: 28px;
    }
    h1, h2, h3 { margin: 0; letter-spacing: 0; }
    h1 { font-size: 30px; }
    h2 { font-size: 20px; margin: 28px 0 12px; }
    h3 { font-size: 15px; }
    .meta { color: var(--muted); margin-top: 6px; }
    .summary {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
      gap: 12px;
      margin: 18px 0;
    }
    .metric {
      border: 1px solid var(--line);
      border-radius: 8px;
      padding: 14px;
      background: var(--panel);
    }
    .metric strong { display: block; font-size: 26px; }
    table {
      width: 100%;
      border-collapse: collapse;
      table-layout: fixed;
      border: 1px solid var(--line);
    }
    th, td {
      text-align: left;
      vertical-align: top;
      padding: 10px;
      border-bottom: 1px solid var(--line);
      overflow-wrap: anywhere;
    }
    th {
      background: var(--panel);
      color: var(--muted);
      font-size: 12px;
      text-transform: uppercase;
    }
    .score {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-width: 44px;
      height: 28px;
      border-radius: 6px;
      background: var(--accent);
      color: white;
      font-weight: 700;
    }
    .tier { font-weight: 700; }
    .muted { color: var(--muted); }
    .chips { display: flex; flex-wrap: wrap; gap: 6px; }
    .chip {
      border: 1px solid var(--line);
      border-radius: 999px;
      padding: 3px 8px;
      font-size: 12px;
      background: #ffffff;
    }
    ul { padding-left: 20px; }
    a { color: #0f5e9c; }
  </style>
</head>
<body>
  <main>
    <header>
      <h1>Daily Opportunity Intelligence Report</h1>
      <div class="meta">Generated {{ generated_at.strftime("%Y-%m-%d %H:%M UTC") }}</div>
    </header>

    <section>
      <h2>Executive Summary</h2>
      <div class="summary">
        <div class="metric"><strong>{{ ranked_opportunities|length }}</strong><span>ranked opportunities</span></div>
        <div class="metric"><strong>{{ high_value|length }}</strong><span>Tier A/B opportunities</span></div>
        <div class="metric"><strong>{{ signals.skill_gaps|length }}</strong><span>tracked skill gaps</span></div>
      </div>
    </section>

    <section>
      <h2>Priority Opportunities</h2>
      <table>
        <thead>
          <tr>
            <th style="width: 18%;">Organization</th>
            <th style="width: 24%;">Title</th>
            <th style="width: 10%;">Score</th>
            <th style="width: 10%;">Tier</th>
            <th style="width: 20%;">Strengths</th>
            <th style="width: 18%;">Action</th>
          </tr>
        </thead>
        <tbody>
          {% for opportunity, score in ranked_opportunities %}
          <tr>
            <td>{{ opportunity.organization }}<br><span class="muted">{{ opportunity.source }}</span></td>
            <td>
              {% if opportunity.url %}<a href="{{ opportunity.url }}">{{ opportunity.title }}</a>{% else %}{{ opportunity.title }}{% endif %}
              <br><span class="muted">{{ opportunity.location or "Location unavailable" }}</span>
            </td>
            <td><span class="score">{{ score.alignment_score }}</span></td>
            <td class="tier">{{ score.tier }}</td>
            <td>
              <div class="chips">
                {% for strength in score.strengths[:5] %}
                <span class="chip">{{ strength }}</span>
                {% endfor %}
              </div>
            </td>
            <td>{{ score.engagement_priority.replace("_", " ") }}<br><span class="muted">{{ score.strategic_fit }}</span></td>
          </tr>
          {% else %}
          <tr><td colspan="6">No ranked opportunities are available yet.</td></tr>
          {% endfor %}
        </tbody>
      </table>
    </section>

    <section>
      <h2>Emerging Market Signals</h2>
      <h3>Trending Technologies</h3>
      <p>{{ signals.trending_technologies[:10] }}</p>
      <h3>Trending Domains</h3>
      <p>{{ signals.trending_domains[:10] }}</p>
    </section>

    <section>
      <h2>Gap Analysis</h2>
      <ul>
        {% for gap, count in signals.skill_gaps[:10] %}
        <li>{{ gap }} appeared in {{ count }} relevant opportunities.</li>
        {% else %}
        <li>No recurring gaps were detected in the current opportunity set.</li>
        {% endfor %}
      </ul>
    </section>

    <section>
      <h2>Strategic Recommendations</h2>
      <ul>
        {% for recommendation in recommendations %}
        <li>{{ recommendation }}</li>
        {% endfor %}
      </ul>
    </section>
  </main>
</body>
</html>

